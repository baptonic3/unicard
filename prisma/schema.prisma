// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AccessItem {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  description     String
  imageUrl        String?
  priceUSDC       Float
  chainItemId     Int?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  passes          Pass[]
  checkoutSessions CheckoutSession[]
}

model Pass {
  id             String     @id @default(cuid())
  itemId         String
  item           AccessItem @relation(fields: [itemId], references: [id])
  buyerAddress   String
  buyerEmail     String?
  particleTxId   String
  arbitrumTxHash String?
  chainPassId    Int?
  status         String     @default("pending")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model CheckoutSession {
  id           String     @id @default(cuid())
  itemId       String
  item         AccessItem @relation(fields: [itemId], references: [id])
  successUrl   String
  cancelUrl    String
  webhookUrl   String?
  metadata     String?    // JSON blob — seller attaches any data
  status       String     @default("open")  // open | complete | expired
  passId       String?
  buyerAddress String?
  particleTxId String?
  createdAt    DateTime   @default(now())
  expiresAt    DateTime
}
