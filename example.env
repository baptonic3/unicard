# Prisma Connection String for PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=

# Magic
NEXT_PUBLIC_MAGIC_API_KEY=pk_live_YOUR_KEY_HERE

# Particle Network
NEXT_PUBLIC_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_CLIENT_KEY=YOUR_CLIENT_KEY
NEXT_PUBLIC_APP_ID=YOUR_APP_UUID

# Arbitrum
NEXT_PUBLIC_ARB_RPC_URL=https://arb1.arbitrum.io/rpc

# MUST be a private key with ETH on Arbitrum to pay for issuing passes
DEPLOYER_PRIVATE_KEY=YOUR_DEPLOYER_PRIVATE_KEY

# To run this locally, you must deploy your own UniCardAccess.sol contract 
# using the DEPLOYER_PRIVATE_KEY above, and place its address here:
NEXT_PUBLIC_ACCESS_PASS_CONTRACT=YOUR_OWN_DEPLOYED_CONTRACT_ADDRESS

NEXT_PUBLIC_TREASURY_WALLET=YOUR_TREASURY_WALLET_ADDRESS
ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY
